# CeramiCraft Local Stack - Environment Variables
# Copy this to .env and fill in values

# ============================================================
# SERVICE IMAGE TAGS (REQUIRED — no defaults, must be explicit)
# ============================================================
# Format: dev-YYYYMMDDHHMM or debug-YYYYMMDDHHMM
PRODUCT_MS_TAG=dev-202603291938
ORDER_MS_TAG=dev-202604022200
USER_MS_TAG=v202603291933
COMMENT_MS_TAG=debug-202603291606
PAYMENT_MS_TAG=dev-202603291946
LOG_MS_TAG=dev-202604050439
NOTIFICATION_MS_TAG=dev-202604050432
MCP_SERVER_TAG=dev-202604050439

# ============================================================
# INFRASTRUCTURE (with defaults — works out of the box)
# ============================================================
MYSQL_PASSWORD=ceramicraft123
POSTGRES_USER=ceramicraft
POSTGRES_PASSWORD=ceramicraft123

# ============================================================
# GO SERVICES (shared — REQUIRED)
# ============================================================
JWT_SECRET=

# Vault — local dev mode (no config needed, handled by vault + vault-init containers)
# If you need to connect to a remote Vault instead, override these:
# VAULT_ADDR=https://vault.local:8200
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# ============================================================
# USER-MS (Zitadel integration — REQUIRED for auth)
# ============================================================
# API keys (JSON) — required for token introspection
ZITADEL_APP_API_KEY=
ZITADEL_SERVICE_API_KEY=

# OAuth client credentials — required for merchant login flow
ZITADEL_ADMIN_CLIENT_ID=
ZITADEL_ADMIN_CLIENT_SECRET=

# SMTP for email notifications (optional)
SMTP_PASSWORD=
SMTP_EMAIL_FROM=

# RBAC project (Zitadel)
RBAC_PROJECT_ID=

# ============================================================
# NOTIFICATION-MS (optional)
# ============================================================
# Firebase Cloud Messaging JSON credentials (optional)
FIREBASE_CREDENTIALS_JSON=

# ============================================================
# MLFLOW (optional — defaults work out of the box)
# ============================================================
MLFLOW_DB_PASSWORD=MlflowDefaultPass2026!
